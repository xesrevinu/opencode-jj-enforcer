{
  "name": "@xesrevinu/opencode-jj-enforcer",
  "version": "0.1.0",
  "description": "OpenCode plugin that enforces jj over git when a workspace contains a .jj repository.",
  "keywords": [
    "git",
    "jj",
    "jujutsu",
    "opencode",
    "opencode-plugin",
    "policy"
  ],
  "homepage": "https://github.com/xesrevinu/opencode-jj-enforcer#readme",
  "bugs": {
    "url": "https://github.com/xesrevinu/opencode-jj-enforcer/issues"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/xesrevinu/opencode-jj-enforcer.git"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "sideEffects": false,
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "prepare": "lefthook install",
    "build": "tsdown",
    "dev": "tsdown --watch",
    "lint": "oxlint .",
    "format": "oxfmt .",
    "format:check": "oxfmt --check .",
    "typecheck": "tsc --noEmit",
    "test": "bun test",
    "check": "bun run lint && bun run format:check && bun run typecheck && bun run test && bun run build",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "changeset publish --provenance",
    "prepack": "bun run build"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.2.15"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.7",
    "@types/bun": "^1.3.10",
    "@types/node": "^24.5.2",
    "lefthook": "^1.11.13",
    "oxfmt": "^0.38.0",
    "oxlint": "^1.53.0",
    "tsdown": "^0.15.5",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.2.0"
  },
  "engines": {
    "bun": ">=1.3.10",
    "node": ">=24"
  }
}
